APP_NAME=Multi-Stage Prompt-Agent Automated Fact Checking System
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_FRONTEND_ORIGIN=http://localhost:3000
APP_API_V1_PREFIX=/api/v1

FACT_CHECK_PROVIDER=mock
FACT_CHECK_OPENAI_MODEL=gpt-4.1-mini
FACT_CHECK_OPENAI_API_KEY=

FACT_CHECK_DATA_ROOT=../data
FACT_CHECK_EVAL_ROOT=../eval
FACT_CHECK_CORPUS_PATH=
FACT_CHECK_RETRIEVAL_INDEX_PATH=
FACT_CHECK_SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

FACT_CHECK_MAX_CLAIMS_PER_REQUEST=12
FACT_CHECK_MAX_STAGE_RETRIES=2
FACT_CHECK_MAX_PIPELINE_LOOPS=1
FACT_CHECK_CONSERVATIVE_NEI_THRESHOLD=0.48
